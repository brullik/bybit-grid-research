# Local configuration template. Copy to .env; never commit the resulting file.
# Secrets belong only in an approved local/VPS secret store.

BYBIT_ENV=mainnet
BYBIT_API_BASE_URL=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_RECV_WINDOW=5000

# Safe defaults. These flags do not authorize live operations.
LIVE_TRADING_ENABLED=false
ALLOW_LIVE_TRADING=NO

DATA_DIR=./data
LOG_LEVEL=INFO

# Native Futures Grid validate is disabled by default and locked to this endpoint.
GRID_VALIDATE_ENABLED=false
BYBIT_FGRID_VALIDATE_PATH=/v5/fgridbot/validate
BYBIT_FGRID_GRID_MODE_NEUTRAL=1
BYBIT_FGRID_GRID_TYPE_GEOMETRIC=2

